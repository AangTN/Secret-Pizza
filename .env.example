# Docker Compose runtime settings
FRONTEND_PORT=80
DB_PORT=5432

# PostgreSQL service used by docker-compose
POSTGRES_DB=secretpizza
POSTGRES_USER=secretpizza
POSTGRES_PASSWORD=change_me_strong_password

# Optional: override full backend connection string
# DATABASE_URL=postgresql://secretpizza:change_me_strong_password@db:5432/secretpizza

# Frontend build-time values
VITE_API_BASE_URL=http://localhost
VITE_MAP_KEY=
VITE_CLIENT_ID=