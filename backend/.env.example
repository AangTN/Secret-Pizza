NODE_ENV=production
PORT=3001

# Database (only needed when running backend outside docker-compose)
# Docker deploy reads DATABASE_URL from root .env or builds it from POSTGRES_*.
DATABASE_URL=postgresql://secretpizza:change_me_strong_password@localhost:5432/secretpizza

# Frontend domain for links and CORS
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# Auth
USER_JWT_SECRET=replace_this_user_secret
ADMIN_JWT_SECRET=replace_this_admin_secret
EMAIL_VERIFY_JWT_SECRET=replace_this_email_verify_secret
EMAIL_VERIFY_TOKEN_EXPIRES=30m

# Google Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=postmessage

# Email
EMAIL_USER=
EMAIL_PASS=

# Optional integrations
GEMINI_API_KEY=
MAPS_API_KEY=

# VNPay (sandbox defaults exist in code, override for production)
VNP_TMNCODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_API=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNP_RETURN_URL=https://your-domain.com/api/payment/vnpay-return